---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import toolheadsData from '../data/toolheads.json';
import CatalogTileGrid from './CatalogTileGrid.astro';

const toolheads = toolheadsData.toolheads;
function inCategory(categoryValue: string | string[] | undefined, targetCategory: string): boolean {
  if (Array.isArray(categoryValue)) return categoryValue.includes(targetCategory);
  return categoryValue === targetCategory;
}

const fullSize = toolheads.filter((t) => inCategory(t.category, 'Full Size Printers'));
const ants = toolheads.filter((t) => inCategory(t.category, 'Printers for Ants'));
---

<Tabs syncKey="Toolheads">
  <TabItem label="Full Size Printers">
    <CatalogTileGrid items={fullSize} accentColor="green" secondaryFields={[{ field: 'hotend_fan', prefix: 'Hotend Fan' }, { field: 'part_cooling_fan', prefix: 'Part Cooling' }]} />
  </TabItem>

  <TabItem label="Printers for Ants">
    <CatalogTileGrid items={ants} accentColor="green" secondaryFields={[{ field: 'hotend_fan', prefix: 'Hotend Fan' }, { field: 'part_cooling_fan', prefix: 'Part Cooling' }]} />
  </TabItem>
</Tabs>
