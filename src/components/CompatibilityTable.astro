---
const { items, type } = Astro.props;
---

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Mounting</th>
      <th>Type</th>
      <th>Flow</th>
      <th>Nozzles</th>
      <th>Length</th>
    </tr>
  </thead>
  <tbody>
    {items.map((item: any) => (
      <tr>
        <td>{item.name}</td>
        <td>{item.mounting_pattern.join(", ")}</td>
        <td>{item.hotend_type ?? item.flow_rate}</td>
        <td>{item.flow_rate}</td>
        <td>{item.nozzle_compatibility.join(", ")}</td>
        <td>{item.length}</td>
      </tr>
    ))}
  </tbody>
</table>
