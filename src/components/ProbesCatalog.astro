---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import probesData from '../data/probes.json';
import CatalogTileGrid from './CatalogTileGrid.astro';

const probes = probesData.probes;
const touch = probes.filter(p => p.type === 'touch');
const touchless = probes.filter(p => p.type === 'touchless');
const dockable = probes.filter(p => p.type === 'dockable');
const nozzle = probes.filter(p => p.type === 'nozzle');
const bedScanner = probes.filter(p => p.type === 'bed_scanner');
---

<Tabs syncKey="Probes">
  <TabItem label="Touch Probes">
    <CatalogTileGrid items={touch} badgeField="type" accentColor="purple" />
  </TabItem>

  <TabItem label="Touchless Probes">
    <CatalogTileGrid items={touchless} badgeField="type" accentColor="purple" />
  </TabItem>

  <TabItem label="Dockable Probes">
    <CatalogTileGrid items={dockable} badgeField="type" accentColor="purple" />
  </TabItem>

  <TabItem label="Nozzle Probes">
    <CatalogTileGrid items={nozzle} badgeField="type" accentColor="purple" />
  </TabItem>

  <TabItem label="Bed Scanner Probes">
    <CatalogTileGrid items={bedScanner} badgeField="type" accentColor="purple" />
  </TabItem>
</Tabs>
