---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import hotendsData from '../data/hotends.json';

const hotends = hotendsData.hotends;
const sf = hotends.filter(h => h.hotend_type === 'SF');
const hf = hotends.filter(h => h.hotend_type === 'HF');
const uhf = hotends.filter(h => h.hotend_type === 'UHF');
---

<Tabs syncKey="hotends">
  <TabItem label="Standard Flow (SF)">
    <ul>
      {sf.map(h => (
        <li><a href={h.url} target="_blank" rel="noopener noreferrer">{h.name}</a>{h.description ? ` - ${h.description}` : ''}</li>
      ))}
    </ul>
  </TabItem>

  <TabItem label="High Flow (HF)">
    <ul>
      {hf.map(h => (
        <li><a href={h.url} target="_blank" rel="noopener noreferrer">{h.name}</a>{h.description ? ` - ${h.description}` : ''}</li>
      ))}
    </ul>
  </TabItem>

  <TabItem label="Ultra High Flow (UHF)">
    <ul>
      {uhf.map(h => (
        <li><a href={h.url} target="_blank" rel="noopener noreferrer">{h.name}</a>{h.description ? ` - ${h.description}` : ''}</li>
      ))}
    </ul>
  </TabItem>
</Tabs>
