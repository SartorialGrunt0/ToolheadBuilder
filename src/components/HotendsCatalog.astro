---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import hotendsData from '../data/hotends.json';
import CatalogTileGrid from './CatalogTileGrid.astro';

const hotends = hotendsData.hotends;
const sf = hotends.filter(h => h.hotend_type === 'SF');
const hf = hotends.filter(h => h.hotend_type === 'HF');
const uhf = hotends.filter(h => h.hotend_type === 'UHF');
---

<Tabs syncKey="hotends">
  <TabItem label="Standard Flow (SF)">
    <CatalogTileGrid items={sf} badgeField="hotend_type" accentColor="green" secondaryFields={[{ field: 'flow_rate', prefix: 'Flow' }, { field: 'mounting_pattern', prefix: 'Mount' }, { field: 'meltzone_length', prefix: 'Meltzone' }]} />
  </TabItem>

  <TabItem label="High Flow (HF)">
    <CatalogTileGrid items={hf} badgeField="hotend_type" accentColor="green" secondaryFields={[{ field: 'flow_rate', prefix: 'Flow' }, { field: 'mounting_pattern', prefix: 'Mount' }, { field: 'meltzone_length', prefix: 'Meltzone' }]} />
  </TabItem>

  <TabItem label="Ultra High Flow (UHF)">
    <CatalogTileGrid items={uhf} badgeField="hotend_type" accentColor="green" secondaryFields={[{ field: 'flow_rate', prefix: 'Flow' }, { field: 'mounting_pattern', prefix: 'Mount' }, { field: 'meltzone_length', prefix: 'Meltzone' }]} />
  </TabItem>
</Tabs>
