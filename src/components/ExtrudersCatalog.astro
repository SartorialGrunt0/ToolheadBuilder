---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import extrudersData from '../data/extruders.json';
import CatalogTileGrid from './CatalogTileGrid.astro';

const extruders = extrudersData.extruders;
const bmg = extruders.filter(e => e.gear_type === 'BMG');
const hgxLite = extruders.filter(e => e.gear_type === 'HGX-lite 1.0' || e.gear_type === 'HGX-lite 2.0');
const galileo = extruders.filter(e => e.gear_type === 'Galileo');
const preAssembled = extruders.filter(e => e.category === 'Pre-Assembled Extruders');
const other = extruders.filter(e => e.category === 'Other Extruders');
const legacy = extruders.filter(e => e.category === 'Legacy Extruders');
---

<Tabs syncKey="extruder">
  <TabItem label="BMG Extruders">
    <CatalogTileGrid items={bmg} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>

  <TabItem label="HGX-lite Extruders">
    <CatalogTileGrid items={hgxLite} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>

  <TabItem label="Galileo 2 Extruders">
    <CatalogTileGrid items={galileo} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>

  <TabItem label="Pre-Assembled Extruders">
    <CatalogTileGrid items={preAssembled} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>

  <TabItem label="Other Extruders">
    <CatalogTileGrid items={other} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>

  <TabItem label="Legacy Extruders">
    <CatalogTileGrid items={legacy} badgeField="gear_type" accentColor="blue" secondaryFields={[{ field: 'mounting_pattern', prefix: 'Mount' }]} />
  </TabItem>
</Tabs>
